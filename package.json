{
  "name": "meme-shelf",
  "displayName": "Meme Shelf - AI Powered Meme Picker",
  "version": "1.0.0",
  "description": "A professional AI-integrated browser extension to pick and upload memes instantly. Supports English & Vietnamese, smart caching, and seamless drag-and-drop.",
  "author": "reinhard@info.vn",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "clipboardRead",
      "clipboardWrite",
      "storage"
    ],
    "host_permissions": [
      "https://*/*"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  }
}
